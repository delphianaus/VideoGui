<ui:FluentWindow x:Class="VideoGui.SelectShortUpload" 
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VideoGui" Loaded="Window_Loaded"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        
        ExtendsContentIntoTitleBar="True" WindowBackdropType="Mica" 
        mc:Ignorable="d" Title="Shorts Upload Settings" 

        
         WindowStartupLocation="CenterScreen" Background="gray"
         SizeToContent="Manual" WindowStyle="ToolWindow" 
        Width="670" MinWidth="538" MinHeight="157" Height="213">
    <ui:FluentWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/FluentWindowControls.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BitmapImage x:Key="SET" UriSource="icons/Set.png"></BitmapImage>
            <BitmapImage x:Key="EDIT" UriSource="icons/Edit.png"></BitmapImage>
            <Style x:Key="ToggleStyle1" TargetType="{x:Type ToggleButton}">
                <Setter Property="MinHeight" Value="28"/>
                <Setter Property="MinWidth" Value="40"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ToggleButton}">
                            <Image x:Name="PART_Image"  />
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="true">
                                    <Setter TargetName="PART_Image" Property="Source" Value="{StaticResource EDIT}"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="False">
                                    <Setter TargetName="PART_Image" Property="Source" Value="{StaticResource SET}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </ui:FluentWindow.Resources>
    <Grid Margin="0,0,0,6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Name="SCSS" Grid.Row="0" Title="Shorts Upload Settings" Height="30">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="/Icons/computer.ico" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>
        <Grid Grid.Row="1" Margin="0,4,0,0" MinWidth="670" MinHeight="157" MaxWidth="670" 
              MaxHeight="157">
            <GroupBox x:Name="brdFileInfo" BorderThickness="1,1,1,1" BorderBrush="White"
                   Margin="4,4,5,17" Header="shorts Upload Settings" SnapsToDevicePixels="True" 
                    MaxHeight="105" Width="661" Height="103" HorizontalAlignment="Left" 
                   VerticalAlignment="Top">
                <Canvas x:Name="CnvMedialElements" Width="649" Margin="0,4,0,0">
                    <Label Content="Source File" HorizontalAlignment="Center" VerticalAlignment="Top" Canvas.Left="9" Canvas.Top="14"/>
                    <TextBox x:Name="txtsrcdir" HorizontalAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center" Width="499" Canvas.Left="120" Canvas.Top="13"/>
                    <Button x:Name="btnSelectSourceDir" HorizontalAlignment="Left" VerticalAlignment="Top" Width="20" Height="20" Canvas.Left="624" Canvas.Top="12" Click="btnSelectSourceDir_Click" RenderTransformOrigin="-13.634,1.02" />
                    <Label Content="Number Of Shorts" Canvas.Left="9" Canvas.Top="47" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                    <Label x:Name="lblShortNo" Content="x" Canvas.Left="108" Canvas.Top="47" HorizontalAlignment="Center" VerticalAlignment="Top" Width="29"/>
                    <Label Content="Uploads Per Slot" Canvas.Left="144" Canvas.Top="47" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtMaxUpload" Text="5" HorizontalAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Top" 
                         Width="36" Canvas.Left="244" Canvas.Top="46" KeyDown="txtMaxUpload_KeyDown" LostFocus="txtMaxUpload_LostFocus"/>
                    <Label Content="Max Uploads" Canvas.Left="283" Canvas.Top="47" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                    <TextBox x:Name="txtTotalUploads" Text="100" TextWrapping="Wrap" 
                    Width="32" Canvas.Left="356" Canvas.Top="46" HorizontalAlignment="Center" VerticalAlignment="Top" KeyDown="txtTotalUploads_KeyDown"/>
                    <ToggleButton x:Name="btnEditTitle" Style="{DynamicResource ToggleStyle1}" 
                      Height="24" Width="40" HorizontalAlignment="Center" Click="btnEditTitle_Click"
                  VerticalAlignment="Center" Canvas.Left="427" Canvas.Top="40" />
                    <Label Content="Title" Canvas.Left="402" Canvas.Top="47" HorizontalAlignment="Center" VerticalAlignment="Top" Width="33"/>
                    <ToggleButton x:Name="btnEditDesc" Style="{DynamicResource ToggleStyle1}" 
                    Height="24" Width="40" Click="btnEditDesc_Click" Canvas.Left="506" 
                    Canvas.Top="40" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Label Content="Desc" Canvas.Left="480" Canvas.Top="47" HorizontalAlignment="Center" 
                       VerticalAlignment="Center" />
                </Canvas>
            </GroupBox>
            <Button x:Name="btnClose" Height="35" Width="123" Content="Close" Margin="0,0,10,3" 
                HorizontalAlignment="Right" VerticalAlignment="Bottom" Click="btnClose_Click"/>
            <Button x:Name="btnRunUploaders" Height="24" Width="78" Content="Run Uploaders" Margin="566,0,0,0" FontSize="10" Click="btnRunUploaders_Click"/>
            <CheckBox x:Name="ChkUploadTest" Content="Run Upload Tester" HorizontalAlignment="Left" 
          Margin="4,93,0,15" VerticalAlignment="Bottom"/>

        </Grid>
    </Grid>

</ui:FluentWindow>
