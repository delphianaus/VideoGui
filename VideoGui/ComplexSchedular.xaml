<ui:FluentWindow x:Class="VideoGui.ComplexSchedular"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VideoGui" 
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        xmlns:MSU="clr-namespace:CustomComponents.ListBoxExtensions;assembly=CustomComponents"
        SizeChanged="Window_SizeChanged" Background="Gray"
        mc:Ignorable="d" DataContext="{Binding RelativeSource={RelativeSource Self}}" 
        Title="Complex Schedule Editor" Loaded="Window_Loaded"
        ResizeMode="CanResizeWithGrip" WindowStartupLocation="CenterScreen"  WindowStyle="ToolWindow" >
    <ui:FluentWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/FluentWindowControls.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BitmapImage x:Key="HISTORIC" UriSource="icons/historic.png"/>
            <BitmapImage x:Key="CURRENT" UriSource="icons/Current.png"/>
            <BitmapImage x:Key="FILESOURCE" UriSource="icons/FileSource.png"/>
            <BitmapImage x:Key="DIRECTORYSOURCE" UriSource="icons/DirectorySource.png"/>
            <Style x:Key="ToggleSetEditStyle" TargetType="{x:Type ToggleButton}">
                <Setter Property="MinHeight" Value="28"/>
                <Setter Property="MinWidth" Value="50"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ToggleButton}">
                            <Image x:Name="PART_Image"  />
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="true">
                                    <Setter TargetName="PART_Image" Property="Source" Value="{StaticResource CURRENT}"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="False">
                                    <Setter TargetName="PART_Image" Property="Source" Value="{StaticResource HISTORIC}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="ToggleButtonSourceStyle" TargetType="{x:Type ToggleButton}">
                <Setter Property="MinHeight" Value="20"/>
                <Setter Property="MinWidth" Value="40"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ToggleButton}">
                            <Image x:Name="PART_Image"  />
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="true">
                                    <Setter TargetName="PART_Image" Property="Source" Value="{StaticResource DIRECTORYSOURCE}"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="False">
                                    <Setter TargetName="PART_Image" Property="Source" Value="{StaticResource FILESOURCE}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </ui:FluentWindow.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Name="complextitle" Grid.Row="0" Title="Complex Schedule Editor" Height="30">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="/Icons/computer.ico" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>
        <Grid Grid.Row="1">
            <Border x:Name="BrdFLags" Height="39"  BorderBrush="White" BorderThickness="2" VerticalAlignment="Top" Width="533" HorizontalAlignment="Left">
                <Canvas x:Name="CnvFags" HorizontalAlignment="Left" VerticalAlignment="Top">
                    <CheckBox x:Name="Chk720P" Content="720p Video" HorizontalAlignment="Center" 
                       VerticalAlignment="Top" Canvas.Left="5" Canvas.Top="8"/>
                    <CheckBox x:Name="ChkShorts" Content="Shorts Generation" 
                      VerticalAlignment="Center" Canvas.Left="87" Canvas.Top="8" 
                      HorizontalAlignment="Left"/>
                    <CheckBox x:Name="ChkCut" Content="Video Cut Trim" HorizontalAlignment="Left" VerticalAlignment="Center" Canvas.Left="200" Canvas.Top="8"/>
                    <CheckBox x:Name="ChkEnableTrim" Content="Video Encode Trim" HorizontalAlignment="Left" VerticalAlignment="Center" Canvas.Left="299" Canvas.Top="8"/>
                    <CheckBox x:Name="ChkTwitch" Content="Twitch" Canvas.Left="419" Canvas.Top="8" HorizontalAlignment="Left" VerticalAlignment="Center" LostFocus="ChkTwitch_LostFocus"/>
                    <CheckBox x:Name="ChkMuxer" Content="Mux" Canvas.Left="478" Canvas.Top="8" HorizontalAlignment="Left" VerticalAlignment="Center" LostFocus="ChkTwitch_LostFocus"/>
                </Canvas>
            </Border>
            <Border x:Name="brdtimes" BorderBrush="White" BorderThickness="2" Width="375" Height="39" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="535,0,0,0">
                <Canvas x:Name="CnvTimes" Height="39" Margin="0,0,0,-4" 
                       HorizontalAlignment="Left" Width="373">
                    <Label Content="Start" HorizontalAlignment="Left" VerticalAlignment="Center" 
                      Height="26" Canvas.Top="3" Canvas.Left="3" VerticalContentAlignment="Center"/>
                    <TextBox x:Name="txtStart" HorizontalAlignment="Left" Canvas.Left="34"
                      TextWrapping="Wrap" VerticalAlignment="Center" Width="94"  Canvas.Top="7"/>
                    <Label Content="Duration" HorizontalAlignment="Left" VerticalAlignment="Center" 
                      Height="26" Canvas.Left="131" Canvas.Top="3" VerticalContentAlignment="Center"/>
                    <TextBox x:Name="txtDuration" HorizontalAlignment="Left" TextWrapping="Wrap"
                     VerticalAlignment="Center" Width="94" Canvas.Left="188" Canvas.Top="7" />
                    <CheckBox x:Name="ChkElapsed" IsChecked="True" Content="Elapsed" Canvas.Left="287" Canvas.Top="8" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                </Canvas>
            </Border>
            <Border x:Name="brdFileInfo" BorderThickness="2" BorderBrush="White" Height="136" Margin="0,44,0,0" Width="912" HorizontalAlignment="Left" VerticalAlignment="Top">
                <Canvas x:Name="CnvMedialElements" Margin="0,6,0,0" Focusable="True">
                    <Label x:Name="lblSourceInfo" Content="Source Directory" HorizontalAlignment="Center" 
                       VerticalAlignment="Top" Canvas.Left="8" Canvas.Top="3" HorizontalContentAlignment="Center"/>
                    <TextBox x:Name="txtsrcdir" HorizontalAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center" 
                      Width="710" Canvas.Left="145" Canvas.Top="2" HorizontalContentAlignment="Center"/>
                    <Label Content="Destination Directory" HorizontalAlignment="Center" VerticalAlignment="Top" Canvas.Left="9" Canvas.Top="27"/>
                    <Button x:Name="btnSelectDestDir" HorizontalAlignment="Center" Width="19" Height="20" Canvas.Left="865" Canvas.Top="24" Click="btnSelectDestDir_Click"/>
                    <TextBox x:Name="txtFilename" HorizontalAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Top" Width="645" Canvas.Left="145" Canvas.Top="50" />
                    <Label Content="Destination Filename" HorizontalAlignment="Center" VerticalAlignment="Top" Canvas.Left="9" Canvas.Top="51"/>
                    <TextBox x:Name="txtdestdir" HorizontalAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center" Width="710" Canvas.Left="145" Canvas.Top="26" />
                    <Button x:Name="btnSelectSourceDir" HorizontalAlignment="Center" Width="20" Height="20" Canvas.Left="865" Click="btnSelectSourceDir_Click" />
                    <CheckBox x:Name="chkDeleteMonitored" Content="Delete Monitored Source" HorizontalAlignment="Center" VerticalAlignment="Top" Canvas.Left="13" Canvas.Top="94"/>
                    <ToggleButton x:Name="tbSource" Style="{DynamicResource ToggleButtonSourceStyle}"
                          IsChecked="True" VerticalAlignment="Top" 
                          Canvas.Top="91" Canvas.Left="283" Width="90" Height="26"
                           Click="tbSource_Click" HorizontalAlignment="Center" />
                    <CheckBox x:Name="chkPersistantSource" Content="Persistant Job" HorizontalAlignment="Center" VerticalAlignment="Top" Canvas.Left="181" Canvas.Top="94"/>
                    <Button x:Name="btnInject" Width="56" Height="41" HorizontalAlignment="Left" VerticalAlignment="Center" Content="Inject" Canvas.Top="80" Canvas.Left="746" Click="btnInject_Click"/>
                    <Button x:Name="btnNew" Width="68" HorizontalAlignment="Center" VerticalAlignment="Center" Content="New" Canvas.Top="80" Canvas.Left="665" Height="41" Click="btnNew_Click"/>
                    <ToggleButton x:Name="tglflip" 
                                      Style="{DynamicResource ToggleSetEditStyle}" 
                                      Width="73" Height="40" 
                                      HorizontalAlignment="Center" 
                                      Click="tglflip_Click" 
                                      IsChecked="True" 
                                      Checked="tglflip_Checked" 
                                      Canvas.Left="815" 
                                      Canvas.Top="82" VerticalAlignment="Top"/>
                    <xctk:DateTimePicker Name="ReleaseDate" Format="Custom" Visibility="Hidden"
                                                   FormatString="MM-dd-yy hh:mm:ss tt" TimeFormat="Custom" TimeFormatString="hh:mm:ss tt"  
                                                   MinWidth="195" Value="{Binding ReleaseDate}" HorizontalAlignment="Left" 
                                                   VerticalAlignment="Center" Focusable="True" Canvas.Left="466" Canvas.Top="80" 
                                             Height="42" AutoCloseCalendar="True" Width="122"   />
                    <TextBox x:Name="txtMuxExt" Canvas.Left="461" TextWrapping="Wrap" 
                                 Text="b,p,o" Canvas.Top="105" Width="188" Visibility="Hidden" 
                                 HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <Label Name="lblmux" Content="Mux Extensions" Height="26" Canvas.Left="459" 
                               Canvas.Top="80" HorizontalAlignment="Left" Visibility="Hidden"
                               VerticalAlignment="Center"/>
                    <Button x:Name="btnAddMux" Click="btnAddMux_Click" Content="Add Muxes" 
                                Width="82" Height="21" HorizontalAlignment="Left" Canvas.Left="567" VerticalAlignment="Center" 
                                Canvas.Top="82" FontSize="10" Visibility="Hidden"/>
                </Canvas>
            </Border>
            <MSU:MultiListbox x:Name="msuComplexSchedules" Header="Complex Schedules" IsDarkMode="True"
                          Width="913" ItemHeight="15" Canvas.Top="2" FontSize="13"
                          Margin="0,177,0,0" Height="199" VerticalAlignment="Top" 
                         HorizontalAlignment="Left" >
                <MSU:MultiListbox.ColumnDefinitions>
                    <MSU:MultiListboxColumnDefinition DataField="Id" Width="0" ComponentType="TextBlock"/>
                    <MSU:MultiListboxColumnDefinition DataField="SRC" HeaderText="Source Directory" 
                     WidthBinding="SrcFileNameWidth" ComponentType="TextBlock"/>
                    <MSU:MultiListboxColumnDefinition DataField="DEST" WidthBinding="DestFileNameWidth"
                     HeaderText="Destination File"/>
                    <MSU:MultiListboxColumnDefinition DataField="Times" HeaderText="Times"
                     Width="107" ComponentType="TextBlock"/>
                    <MSU:MultiListboxColumnDefinition DataField="RecordAge" HeaderText="Age"
                     Width="30" ComponentType="TextBlock"/>
                    <MSU:MultiListboxColumnDefinition DataField="ProceessingType" HeaderText="Processing Type"
                     Width="100" ComponentType="TextBlock"/>
                    <MSU:MultiListboxColumnDefinition DataField="ProcessingActions" HeaderText="Processing Actions"
                     Width="110" ComponentType="TextBlock"/>
                </MSU:MultiListbox.ColumnDefinitions>
                <MSU:MultiListbox.ItemsContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Delete Selected Entry" Click="mnuDeleteEntry_Click"  />
                        <MenuItem Header="Paste Group Times" Click="mnuGroupPaste_Click"  />
                        <MenuItem Header="Change Destination Header" Click="mnuChangeDestHeaderHistoric_Click"/>
                        <MenuItem Header="Change Filename Header" Click="mnuChangeFilenameHeaderHistoric_Click"/>
                    </ContextMenu>
                </MSU:MultiListbox.ItemsContextMenu>
            </MSU:MultiListbox>
            <Button x:Name="btnCloe" Content="Close" Width="90"
                Height="30" Click="btnCloe_Click" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,13,13"/>
        </Grid>
    </Grid>
</ui:FluentWindow>
