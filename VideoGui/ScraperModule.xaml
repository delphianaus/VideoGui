<ui:FluentWindow  x:Name="mainwindow" x:Class="VideoGui.ScraperModule"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:xctk="clr-namespace:VideoGui" 
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d" 
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        ExtendsContentIntoTitleBar="True" WindowBackdropType="Mica"
        ResizeMode="CanResize" WindowStartupLocation="CenterScreen" 
        WindowStyle="ToolWindow" 
        Title="YouTube Uploader Module" Height="450" Width="800" Loaded="Window_Loaded" 
        SizeChanged="Window_SizeChanged" KeyDown="mainwindow_KeyDown" 
        Icon="/Icons/computer.ico" ShowInTaskbar="False">
    <ui:FluentWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/FluentWindowControls.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </ui:FluentWindow.Resources>
    <Grid UseLayoutRounding="True" x:Name="gridmain">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Name="YUM" Grid.Row="0" Title="YouTube Uploader Module" Height="30">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="/Icons/computer.ico" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>
        <Grid Grid.Row="1" Width="NaN">
            <Border x:Name="brdmain" BorderBrush="Black" BorderThickness="3" Margin="2,1,3,40" AllowDrop="True"
                VerticalAlignment="Top" Height="290" SizeChanged="brdmain_SizeChanged">
                <wv2:WebView2 x:Name="wv2" Margin="3,3,3,3" ZoomFactor="0.5" MouseMove="wv2_MouseMove" 
              NavigationCompleted="wv2_NavigationCompleted" IsManipulationEnabled="True" />
            </Border>
            <Border x:Name="brdmainA1" VerticalAlignment="Bottom" Margin="2,2,2,121">
                <wv2:WebView2 x:Name="wv2A1" Height="0" NavigationCompleted="Wv2s_NavigationCompleted"/>
            </Border>
            <Border x:Name="brdmainA2" VerticalAlignment="Top">
                <wv2:WebView2 x:Name="wv2A2" Height="0" AllowDrop="True" NavigationCompleted="Wv2s_NavigationCompleted"/>
            </Border>
            <Border x:Name="brdmainA3" VerticalAlignment="Top">
                <wv2:WebView2 x:Name="wv2A3" Height="0" AllowDrop="True" NavigationCompleted="Wv2s_NavigationCompleted"/>
            </Border>
            <Border x:Name="brdmainA4" VerticalAlignment="Top">
                <wv2:WebView2 x:Name="wv2A4" Height="0" AllowDrop="True" NavigationCompleted="Wv2s_NavigationCompleted"/>
            </Border>
            <Border x:Name="brdmainA5" VerticalAlignment="Top">
                <wv2:WebView2 x:Name="wv2A5" Height="0" AllowDrop="True" NavigationCompleted="Wv2s_NavigationCompleted"/>
            </Border>
            <Border x:Name="brdmainA6" VerticalAlignment="Top">
                <wv2:WebView2 x:Name="wv2A6" Height="0" AllowDrop="True" NavigationCompleted="Wv2s_NavigationCompleted"/>
            </Border>
            <Border x:Name="brdmainA7" VerticalAlignment="Top">
                <wv2:WebView2 x:Name="wv2A7" Height="0" AllowDrop="True" NavigationCompleted="Wv2s_NavigationCompleted"/>
            </Border>
            <Border x:Name="brdmainA8" VerticalAlignment="Top">
                <wv2:WebView2 x:Name="wv2A8" Height="0" AllowDrop="True" NavigationCompleted="Wv2s_NavigationCompleted"/>
            </Border>
            <Border x:Name="brdmainA9" VerticalAlignment="Top">
                <wv2:WebView2 x:Name="wv2A9" Height="0" AllowDrop="True" NavigationCompleted="Wv2s_NavigationCompleted"/>
            </Border>
            <Border x:Name="brdmainA10" VerticalAlignment="Top">
                <wv2:WebView2 x:Name="wv2A10" Height="0" AllowDrop="True" NavigationCompleted="Wv2s_NavigationCompleted"/>
            </Border>
            <Border x:Name="brdInfo" BorderBrush="Black" BorderThickness="2" Margin="2,1,3,42" 
                VerticalAlignment="Bottom" >
                <ListBox x:Name="lstMain" HorizontalAlignment="Left" 
                     VerticalAlignment="Center" 
                     MinHeight="100" MinWidth="799" 
                     
                     Margin="1,0,0,0" IsSynchronizedWithCurrentItem="False" 
                     Padding="0" ScrollViewer.HorizontalScrollBarVisibility="Auto" 
                     ScrollViewer.VerticalScrollBarVisibility="Auto" Height="70" 
                     Width="782" FontSize="11">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Height" Value="22" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Border>
            <Border Name="brdStatusBar" BorderBrush="CadetBlue" BorderThickness="3" VerticalAlignment="Bottom" Margin="1,0,0,2">
                <Grid Name="StatusBar" HorizontalAlignment="Left" 
                   VerticalAlignment="Bottom" Height="37" Background="#FF341919"
                Width="796" ClipToBounds="True" SnapsToDevicePixels="True">
                    <Label x:Name="lblLastNode" Content="Initializing..."  Margin="8,0,0,0" HorizontalAlignment="Left" 
                    VerticalContentAlignment="Center" Padding="0,0,1,0"/>
                    <Label x:Name="lblTotalUploadsText" Content="Total Uploads : " VerticalContentAlignment="Center"
                   HorizontalAlignment="Left" Margin="109,0,0,0" SizeChanged="LabelSizeChanged" 
                IsVisibleChanged="LabelVisibilityChanged"/>
                    <Label x:Name="lblTotal" Content="x" HorizontalAlignment="Left" VerticalContentAlignment="Center"
                Margin="202,0,0,0" />
                    <Label x:Name="lblUploadingText" Content="Uploading : " HorizontalAlignment="Left" Margin="357,0,0,0" 
                  VerticalContentAlignment="Center" IsVisibleChanged="LabelVisibilityChanged" 
                  SizeChanged="LabelSizeChanged" />
                    <Label x:Name="lblUploading" Content="x" HorizontalAlignment="Left" Margin="434,0,0,0" 
                 VerticalContentAlignment="Center"/>
                    <Label x:Name="lblUploadedText" Content="Uploaded : " Margin="264,0,0,0" 
                  VerticalContentAlignment="Center" HorizontalAlignment="Left" 
              SizeChanged="LabelSizeChanged" IsVisibleChanged="LabelVisibilityChanged" />
                    <Label x:Name="lblUploaded" Content="x" HorizontalAlignment="Left" Margin="336,0,0,0" 
                  VerticalContentAlignment="Center" />
                    <Label x:Name="lblWaitingtext" Content="Waiting : " HorizontalAlignment="Left" Margin="481,0,0,0" 
                   VerticalContentAlignment="Center" SizeChanged="LabelSizeChanged" 
                 IsVisibleChanged="LabelVisibilityChanged"/>
                    <Label x:Name="lblWaiting" Content="x" AutomationProperties.IsRowHeader="True" HorizontalAlignment="Left" 
                    VerticalContentAlignment="Center" Margin="548,0,0,0"/>
                    <Label x:Name="lblMouseOverText" Content="Mouse Over : " 
                   HorizontalAlignment="Right" VerticalContentAlignment="Center" Margin="0,0,116,0" Width="67" Visibility="Hidden" />
                    <Label x:Name="lblMouseOver" Content ="x" VerticalAlignment="Center" 
              HorizontalAlignment="Right" Margin="80,0,103,0" Visibility="Hidden" />
                    <Button Name="btnClose" Content="Close" VerticalAlignment="Center"
            Height="26" HorizontalAlignment="Right" 
                    MinWidth="3" Click="btnClose_Click" HorizontalContentAlignment="Center" Width="45" Padding="6,0,0,0" Margin="0,0,7,0"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</ui:FluentWindow>
