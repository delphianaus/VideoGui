<Window x:Class="VideoGui.ThemeExtractor" d:Background="gray"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit" 
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VideoGui"
        mc:Ignorable="d"
        Title="ThemeExtractor" Height="107" Width="212">

    
    <Grid>
        <xctk:DateTimePicker x:Name="ReleaseDate" Format="Custom" 
            FormatString="dd/MM/yyyy" MinWidth="140" Foreground='Bisque'
            Focusable="True" 
    
            AutoCloseCalendar="True" TimePickerAllowSpin="False" 
            TimePickerShowButtonSpinner="False" TimePickerVisibility="Collapsed" 
            Background="#FF383333" HorizontalAlignment="Left" VerticalAlignment="Top" />

    </Grid>
</Window>
