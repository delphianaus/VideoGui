<ui:FluentWindow x:Class="VideoGui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        ExtendsContentIntoTitleBar="True" WindowBackdropType="Mica"
        mc:Ignorable="d" Title="Video Procesor" Name="MainWindowX" WindowStartupLocation="CenterOwner" 
        ResizeMode="CanResize" SizeToContent="Manual" Height="auto" Width="Auto" 
        Loaded="MainWindowX_Loaded" StateChanged="MainWindowX_StateChanged"
        IsVisibleChanged="MainWindowX_IsVisibleChanged" SizeChanged="MainWindowX_SizeChanged" 
        FocusableChanged="Window_FocusableChanged" WindowStyle="ThreeDBorderWindow"
        AutomationProperties.IsColumnHeader="True" GotFocus="MainWindowX_GotFocus" >
    <Grid x:Name="Grid1" Focusable="True" Width="1143" Margin="0,0,0,0" Height="652" >
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Name="guiTitle" Grid.Row="0" Title="VideoGui" Height="30">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="/Icons/computer.ico" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>
        <Grid Grid.Row="1">
            <tb:TaskbarIcon x:Name="trayicon"  IconSource="/Icons/computer.ico"
                ToolTipText="Video Gui" Visibility="Collapsed" TrayMouseDoubleClick="Restore_Click">
                <tb:TaskbarIcon.ContextMenu>
                    <ContextMenu  Background="LightCoral">
                        <MenuItem Header="Restore" Click="Restore_Click"/>
                        <MenuItem Header="Configuration" Click="Show_Config"/>
                        <MenuItem Header="Update" Click="Update_Click" />
                        <MenuItem Header="Open Log File" Click="OpenLogFile_Click"/>
                        <MenuItem Header="Clear Probe Date" Click="MenuItem_Click_1" />
                        <MenuItem Header="Close" Click="Close_Click" />
                    </ContextMenu>
                </tb:TaskbarIcon.ContextMenu>
            </tb:TaskbarIcon>


            <Border x:Name="brdlstbox" BorderThickness="2" BorderBrush="Beige" Margin="5,5,5,115" 
                VerticalAlignment="Top" Height="450" HorizontalAlignment="Left">
                <ListBox x:Name="lstBoxJobs" Margin="1,1,1,1"
                 AllowDrop="True" 
                DragEnter="lstBoxJobs_DragEnter" 
                Drop="lstBoxJobs_Drop" 
                DragOver="lstBoxJobs_DragOver"
                IsTabStop="True" SelectionChanged="lstBoxJobs_SelectionChanged" Width="1099"  
                 VerticalContentAlignment="Stretch" HorizontalContentAlignment="Stretch" ClipToBounds="True" >
                    <ListBox.Resources>
                        <!--Defines a context menu-->
                        <ContextMenu x:Key="MyElementMenu">
                            <MenuItem Header="Process as X264" Click="MenuItem_Click" MouseDown="MenuItem_MouseDown"   
                              MouseUp="MenuItem_MouseUp" />
                            <MenuItem Header="Skip Current File" Click="DeleteFile_Click"/>
                            <MenuItem Header="Open Log File" Click="OpenLogFile_Click"/>

                            <MenuItem Header="Reset Errored Files" Name="ResetErrored" Click="ResetErrored_Click"/>
                            <MenuItem Header="Scan Source Directory" Name="ScanSource" Click="ScanSource_Click" />
                            <MenuItem Header="View Convert Progress Output" Name="ViewOutput" Click="ViewOutput_Click"/>
                        </ContextMenu>
                        <!--Sets a context menu for each ListBoxItem in the current ListBox-->
                        <Style TargetType="{x:Type ListBoxItem}">
                            <Setter Property="ContextMenu" Value="{StaticResource MyElementMenu}"/>
                        </Style>
                    </ListBox.Resources>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="5,2,5,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="40" />
                                    <ColumnDefinition Width="145"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name ="Title" Tag ="0" Text="{Binding Title}">
                                    <TextBlock.FontStyle>
                                        <MultiBinding Converter="{StaticResource BooleanToColorConverter}">
                                            <Binding Mode="OneWay" Path="Items" RelativeSource="{RelativeSource FindAncestor, AncestorType={x:Type ListBox}}"/>
                                            <Binding ElementName ="Title" Path="Text" />
                                            <Binding ElementName ="Title" Path="Tag" />
                                        </MultiBinding>
                                    </TextBlock.FontStyle>
                                </TextBlock>
                                <TextBlock x:Name="FileInfo" Tag ="1" Text="{Binding Fileinfo}"   HorizontalAlignment ="Right" />
                                <ProgressBar Grid.Column="8" Tag ="2" Minimum="0"   x:Name="SubProgressBar"  Maximum="100" 
                                   Value="{Binding Progress}" Margin="5,0,5,0" Height="18" Foreground="Green" >

                                </ProgressBar>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
            <ToggleButton x:Name="GPUEncode" Style="{StaticResource  ToggleStyle1}" 
             Margin="0,0,116,100" Height="24" Width="Auto" HorizontalAlignment="Right" 
             VerticalAlignment="Bottom" IsChecked="False"/>
            <ToggleButton x:Name="X265Output" Style="{StaticResource  ToggleStyle2}"  
             Margin="0,0,220,100" Height="24" Width="98" HorizontalAlignment="Right" 
             VerticalAlignment="Bottom" IsChecked="False" Checked="X265Output_Checked"/>
            <ToggleButton x:Name="Fisheye" Style="{StaticResource  ToggleStyle3}"  
              Margin="10,0,15,100" Height="24"  Width="Auto" HorizontalAlignment="Right" 
               VerticalAlignment="Bottom"/>
            <Button x:Name="btnConfig" Content="Configuration" HorizontalAlignment="Left" 
              Height="26" Margin="8,0,0,136" 
              VerticalAlignment="Bottom" Click="BtnConfig_Click" Width="97" Padding="0,0,0,0"/>
            <Button x:Name="btnstart" Content="Start" Height="26" FontSize="11" Width="97" 
              Margin="8,0,0,169"  HorizontalAlignment="Left" VerticalAlignment="Bottom"
              Click="Btnstart_Click"/>
            <Button x:Name="btnEditDirectories" Content="Edit Directories" Height="26" 
              Margin="228,0,0,102" VerticalAlignment="Bottom" HorizontalAlignment="Left" 
               Click="btnEditDirectories_Click" Width="102"/>
            <Button x:Name="btnEditSchedules" Content="Edit Schedules" Height="26" 
               Margin="335,0,0,102" VerticalAlignment="Bottom" HorizontalAlignment="Left" 
               Click="btnEditSchedules_Click" Width="82"/>
            <Button x:Name="btnEditActions" Content="Edit Actions" Height="26" 
              Margin="423,0,0,102" VerticalAlignment="Bottom" HorizontalAlignment="Left" 
              Click="btnEditActions_Click" Width="68"/>
            <Button x:Name="btnSchedule" Content="Scheduler" Height="26" 
               Margin="496,0,0,102" VerticalAlignment="Bottom" HorizontalAlignment="Left" 
               Click="btnSchedule_Click" Width="60"/>
            <Button x:Name="btnRunTest" Content="Audio Joiner" HorizontalAlignment="Left" 
               Height="26" VerticalAlignment="Bottom" Width="72" Click="btnRunTest_Click" 
             Margin="562,0,0,102"/>
            <Button x:Name="btnShortsCreator" Content="Create Shorts" HorizontalAlignment="Left"
             Height="26" VerticalAlignment="Bottom" Width="74"
              Click="btnShortsCreator_Click" Margin="640,0,0,102"/>
            <Button x:Name="btnThumbnails" Content="Thumbnails Editor" Height="26" 
               Margin="113,0,0,102" VerticalAlignment="Bottom" HorizontalAlignment="Left" Click="btnThumbNails_Click" Width="109"/>
            <Button x:Name="BtnScan" Content="Scanner" HorizontalAlignment="Left" 
              Height="26" VerticalAlignment="Bottom" Width="74" Click="BtnScan_Click" 
              Margin="721,0,0,102"/>
            <Button x:Name="btnShortsInfo" Content="Shorts" HorizontalAlignment="Left" 
              Height="26" Margin="8,0,0,102" VerticalAlignment="Bottom" Width="97" 
              Click="btnShortsInfo_Click"/>
            <ProgressBar x:Name="Progressbar1" HorizontalAlignment="Left" Height="26" 
              Margin="112,0,0,135" VerticalAlignment="Bottom" Width="976" />
            <ProgressBar x:Name="Progressbar2" HorizontalAlignment="Left" Height="26" 
             Margin="112,0,0,169" VerticalAlignment="Bottom" Width="976" />
            <Grid x:Name="StatusTop" Height="34" Margin="5,0,5,52"
              VerticalAlignment="Bottom" HorizontalAlignment="Left" Width="1122" >
                <Label x:Name="lblSpeedStatus" Height="34" 
              Content="Speed" MouseDoubleClick="Label_MouseDoubleClick" FontWeight="DemiBold"
              FontSize="13" HorizontalAlignment="Left" VerticalContentAlignment="Center" 
              HorizontalContentAlignment="Center" Padding="3,0,3,0"/>
                <Label x:Name="lblSpeed" Content="4" HorizontalAlignment="Left" Height="31" 
               VerticalAlignment="Center" Width="47" Margin="39,0,0,0"
                HorizontalContentAlignment="Center" 
               VerticalContentAlignment="Center" />
                <Label x:Name="lblCurrentFrameStatus" Height="31" 
               Content="Current Frame" FontSize="11" HorizontalAlignment="Left" Margin="90,0,0,0"
               HorizontalContentAlignment="Center" VerticalContentAlignment="Center" 
               Padding="3,0,3,0" VerticalAlignment="Center"/>
                <Label x:Name="lblCurrentFrames" Content="frame" HorizontalAlignment="Left"
                 Height="30" VerticalAlignment="Center" Width="41" Margin="293,0,0,0" 
                 HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                <Label x:Name="lblFramesStatus" Height="31" 
               Content="Frames" FontSize="11" Margin="250,0,0,0" HorizontalAlignment="Left" 
               VerticalContentAlignment="Center" HorizontalContentAlignment="Center" 
               Padding="3,0,3,0" VerticalAlignment="Center"/>
                <Label x:Name="lblFrames" Content="" HorizontalAlignment="Left" Height="31" 
               VerticalAlignment="Center" Width="78" Margin="168,0,0,0" 
               VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                <Label x:Name="lblBitrateStatus" Height="34" 
               Content="Bitrate" FontSize="11" HorizontalAlignment="Left" Margin="335,0,0,0" 
               VerticalContentAlignment="Center" VerticalAlignment="Center" 
               HorizontalContentAlignment="Center" Padding="5,0,5,0"/>
                <Label x:Name="lblBitrate" Content="btrte" HorizontalAlignment="Left" Height="31" 
              VerticalAlignment="Center" Width="88" Margin="379,0,0,0" 
              VerticalContentAlignment="Center" />
                <Label x:Name="lblDurationStatus" Width="60" Height="31" 
              Content="Processed" FontSize="11" HorizontalAlignment="Left" 
              VerticalAlignment="Center" Margin="472,0,0,0" HorizontalContentAlignment="Center" 
              VerticalContentAlignment="Center"/>
                <Label x:Name="lblDuration" Content="dur" HorizontalAlignment="Left" Height="31" 
               VerticalAlignment="Center" Width="59" Margin="534,0,0,0" 
               VerticalContentAlignment="Center" HorizontalContentAlignment="Center" />
                <Label x:Name="lblETAStatus" Width="27" Height="30" 
               Content="ETA" FontSize="11" HorizontalContentAlignment="Center" 
               HorizontalAlignment="Left" VerticalAlignment="Center" Margin="597,0,0,0" 
               VerticalContentAlignment="Center"/>
                <Label x:Name="lblEta" Content="ETA" HorizontalAlignment="Left" Height="30" 
               VerticalAlignment="Center" Width="39" Margin="627,0,0,0"
              VerticalContentAlignment="Center"/>
                <Label x:Name="lblTotalTimeStatus" Height="31" 
               Content="Time" FontSize="11" HorizontalContentAlignment="Center" 
               HorizontalAlignment="Left" VerticalAlignment="Center" VerticalContentAlignment="Center" 
               Margin="668,0,0,0" Padding="5,0,5,0" Grid.IsSharedSizeScope="True"/>
                <Label x:Name="lblTotalTime" HorizontalAlignment="Left" Height="31" 
               VerticalAlignment="Center" Width="59" Margin="705,0,0,0" />
                <Label x:Name="lblPercentStatus" Width="47" 
                Height="34" Content="Percent" FontSize="11" VerticalContentAlignment="Center" 
                 VerticalAlignment="Center" HorizontalAlignment="Left" Margin="769,0,0,0" 
                 HorizontalContentAlignment="Center"/>
                <Label x:Name="lblPercent" HorizontalAlignment="Left" Height="32" 
               VerticalAlignment="Center" Width="53" 
               HorizontalContentAlignment="Center" Margin="820,0,0,0" Content="PER" 
              VerticalContentAlignment="Center" />
                <Button x:Name="btnAppliedSchedule" Content="Upload Schedule" 
              HorizontalAlignment="Right" Height="31" VerticalAlignment="Center" 
              Width="130" Click="btnAppliedSchedule_Click" Margin="0,0,112,0"/>
                <Button x:Name="btnYTSchedule" Content="Uploads Info" Height="31" Width="101" 
              Click="btnYTSchedule_Click" HorizontalAlignment="Right"/>
            </Grid>
            <Grid x:Name="StatusBottom" Height="34" Margin="5,0,0,2"
               VerticalAlignment="Bottom" HorizontalAlignment="Left" Width="1128" >
                <Label x:Name="lblTotalStatus" Height="30" BorderBrush="Goldenrod"
               Content="Total Time" FontSize="11" HorizontalAlignment="Left" 
               VerticalAlignment="Center" Padding="5,0,5,0" VerticalContentAlignment="Center"/>
                <Label x:Name="LblTotalTIMEAll" Content="" HorizontalAlignment="Left" Height="31" 
               VerticalAlignment="Center" Width="47" Margin="63,0,0,0" VerticalContentAlignment="Center" />
                <Label x:Name="lblPassFailStatus" Height="31" 
               Content="Pass/Fail" FontSize="11" HorizontalAlignment="Left" Margin="113,0,0,0" 
               Padding="5,0,5,0" VerticalContentAlignment="Center"/>
                <Label x:Name="lblFailpass" Content="" HorizontalAlignment="Left" Height="31" 
               VerticalAlignment="Center" Width="40" Margin="168,0,0,0" />
                <Label x:Name="lblQueStatus" Height="31" 
               Content="Que" FontSize="11" HorizontalAlignment="Left" Margin="210,0,0,0" 
             VerticalAlignment="Center" Padding="5,0,5,0" VerticalContentAlignment="Center"/>
                <Label x:Name="lblQueInfo" HorizontalAlignment="Left" Height="31" 
               VerticalAlignment="Center" Width="45" Margin="242,0,0,0" />
                <Label x:Name="lblAccelStatus" Height="31" 
               Content="Accel HW" FontSize="11" HorizontalAlignment="Left" VerticalAlignment="Center" 
             Padding="5,0,5,0" VerticalContentAlignment="Center" Margin="289,0,0,0"/>
                <Label x:Name="lbAccelHW" Content="" HorizontalAlignment="Left" Height="30" 
               VerticalAlignment="Center" Width="254"  Margin="347,0,0,0"/>
                <Button x:Name="btnScriptEditor" Content="Script Injector"
               Height="30" Click="btnScriptEditor_Click" Padding="5,0,5,0" Width="88" HorizontalAlignment="Right" Margin="0,0,352,0" />
                <Button x:Name="btnMediaImporter" Content="Import Footage"
               Height="30" Click="btnMediaImporter_Click" Padding="5,0,5,0" Width="88" HorizontalAlignment="Right" Margin="0,0,260,0"/>
                <Button x:Name="btnVIdeoEdit" Content="Edit Points" 
               Height="30" Width="63" Click="btnVIdeoEdit_Click" Margin="0,0,191,0" HorizontalAlignment="Right"/>
                <Button x:Name="btnScraperDraft" Content="Scrape Drafts" 
               Height="30" Click="btnScraperDraft_Click" Padding="5,0,5,0" Width="79" HorizontalAlignment="Right" Margin="0,0,110,0"/>
                <Button x:Name="btnSetupload" Content="Uploads Directory" Height="30" Click="btnSetupload_Click" Padding="5,0,5,0" Width="102" HorizontalAlignment="Right" Margin="0,0,5,0"/>
            </Grid>

        </Grid>
    </Grid>
</ui:FluentWindow>
